# Server Environment Variables
# Copy this to .env and fill in your values

PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=innovation_conclave

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Admin credentials (used for seeding — change before production)
ADMIN_EMAIL=admin@innovationconclave.in
ADMIN_PASSWORD=Admin@2026
